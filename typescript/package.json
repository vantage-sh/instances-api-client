{
    "name": "@vantage-sh/instances-api-client",
    "version": "1.0.1",
    "description": "A client for the Vantage Instances API",
    "repository": {
        "type": "git",
        "url": "https://github.com/vantage-sh/instances-api-client"
    },
    "license": "MIT",
    "author": "Vantage",
    "publishConfig": {
        "access": "public"
    },
    "module": "dist/index.mjs",
    "main": "dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsup",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "prettier": "3.6.2",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "node-html-parser": "^7.0.2"
    }
}
